# 웹사이트 루트 도메인 (SEO, sitemap, 이메일 링크용)
NEXT_PUBLIC_SITE_URL=https://yourdomain.co.kr
NEXT_PUBLIC_BASE_URL=https://yourdomain.co.kr

# 검색엔진 소유권 인증
# Google Search Console: https://search.google.com/search-console
# → 속성 추가 → URL 접두사 → "HTML 태그" 방식 → content="..." 값만 복사
NEXT_PUBLIC_GSC_VERIFICATION=

# 네이버 서치어드바이저: https://searchadvisor.naver.com
# → 사이트 등록 → HTML 태그 방식 → content="..." 값만 복사
NEXT_PUBLIC_NAVER_VERIFICATION=

# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX)
# https://analytics.google.com → 관리 → 데이터 스트림 → 웹 스트림 생성
NEXT_PUBLIC_GA_ID=

# 네이버 프리미엄 로그분석 공통 키 (네이버 검색광고 → 도구 → 프리미엄 로그분석)
NEXT_PUBLIC_NAVER_ANALYTICS_ID=

# 카카오톡 채널 URL (예: https://pf.kakao.com/_xxxxxx) — 미설정 시 카톡 버튼 숨김
NEXT_PUBLIC_KAKAO_CHANNEL_URL=

# 카카오맵 API KEY (Javascript 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=YOUR_KAKAO_MAP_KEY_HERE

# Supabase 설정 (사전 테이블 생성 필요)
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Resend API 설정 (이메일 발송용)
RESEND_API_KEY=re_your_api_key

# 솔라피(Solapi) SMS / 카카오 알림톡 설정
# solapi.com → 우상단 프로필 → API Key 관리 → 새 API Key 생성
SOLAPI_API_KEY=YOUR_SOLAPI_API_KEY
SOLAPI_API_SECRET=YOUR_SOLAPI_API_SECRET
SOLAPI_SENDER_PHONE=YOUR_SENDER_PHONE

# 카카오 알림톡 설정 (채널 등록 및 템플릿 승인 완료 후 입력)
SOLAPI_KAKAO_PF_ID=
SOLAPI_KAKAO_TEMPLATE_ID=
